# Consigliere Environment Variables
# Copy to .env and fill in values

# Required
DATABASE_URL=ecto://postgres:postgres@db/consigliere
SECRET_KEY_BASE=changeme_run_mix_phx_gen_secret

# Network: mainnet or testnet
NETWORK=testnet

# BSV Node (optional if using JungleBus)
BSV_NODE_RPC_URL=http://localhost:18332
BSV_NODE_RPC_USER=
BSV_NODE_RPC_PASSWORD=

# ZMQ (optional — from BSV node)
ZMQ_RAW_TX=tcp://localhost:28332
ZMQ_HASH_BLOCK=tcp://localhost:28332

# JungleBus (recommended — no BSV node needed)
JUNGLE_BUS_ENABLED=true
JUNGLE_BUS_URL=https://junglebus.gorillapool.io
JUNGLE_BUS_SUBSCRIPTION_ID=

# Phoenix
PORT=5000
PHX_HOST=localhost
